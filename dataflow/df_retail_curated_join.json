{
	"name": "df_retail_curated_join",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sql_cust_curated",
						"type": "DatasetReference"
					},
					"name": "cust"
				},
				{
					"dataset": {
						"referenceName": "ds_sql_retail_txns_curated",
						"type": "DatasetReference"
					},
					"name": "txns"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_curated_join",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          custid as integer,",
				"          full_name as string,",
				"          profession as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> cust",
				"source(output(",
				"          txndate as date,",
				"          custid as integer,",
				"          amount as double,",
				"          city as string,",
				"          state as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> txns",
				"txns, cust join(txns@custid == cust@custid,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
				"          txndate,",
				"          custid = txns@custid,",
				"          amount,",
				"          city,",
				"          state,",
				"          full_name,",
				"          profession",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}