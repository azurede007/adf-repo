{
	"name": "pl_33_deltalake_sqlserver",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureDatabricksDeltaLakeSource",
						"query": "SELECT * FROM inceptez_insurance.ins_bronze.tblinsclaim LIMIT 10",
						"exportSettings": {
							"type": "AzureDatabricksDeltaLakeExportCommand"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": true,
					"stagingSettings": {
						"linkedServiceName": {
							"referenceName": "ls_blob_retail",
							"type": "LinkedServiceReference"
						},
						"path": "retaildata/delta_to_sql"
					}
				},
				"inputs": [
					{
						"referenceName": "ds_deltalake_insr",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_sqlserver_sales",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}