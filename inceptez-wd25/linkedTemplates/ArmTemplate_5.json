			"metadata": "Data Factory name",
			"defaultValue": "inceptez-wd25"
		},
		"event_trg_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/b5e4da8f-c8ad-48d8-8ecc-f5bc2da0685f/resourceGroups/rg-adf/providers/Microsoft.Storage/storageAccounts/saadlsadf"
		},
		"schedule_trg_properties_pl_12_sql_adls_fixed_window_parameters_pstartdate": {
			"type": "string",
			"defaultValue": "2026-02-03"
		},
		"schedule_trg_properties_pl_12_sql_adls_fixed_window_parameters_penddate": {
			"type": "string",
			"defaultValue": "2026-02-03"
		},
		"trg_tumb_ins_data_process_properties_pipeline_parameters_process_dt": {
			"type": "string",
			"defaultValue": "@formatDateTime(trigger().outputs.windowStartTime, 'yyyy-MM-dd')"
		},
		"tumbling_one_specifc_day_properties_pipeline_parameters_pstartdate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowStartTime"
		},
		"tumbling_one_specifc_day_properties_pipeline_parameters_penddate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndTime"
		}
